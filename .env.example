# ============================================
# NEXUS Daily 开发环境配置模板
# 复制此文件为 .env 并修改为本地开发值
# .env 文件已 gitignore，不会提交到仓库
# ============================================
#
# 键名约定:
#   VITE_*          — 前端配置，由 Vite 自动注入
#   server.*        — 后端 Viper 嵌套键（点号分隔，无需 ISOLO_ 前缀）
#   database.*      — 数据库（同上）
#   auth.*          — JWT 认证（同上）
#   smtp.*          — 邮件（同上）
#   casbin.*        — 权限（同上）
#   collector.*     — 采集器（同上）
#   redis.*         — Redis（同上）
#
# OS 环境变量 ISOLO_* 始终覆盖 .env 中对应的值（最高优先级）
#
# 启动方式:
#   前端: cd web && npm run dev
#   后端: go run ./cmd/server/


# ============================================
# 前端配置（VITE_ 前缀）
# ============================================

# API 基础路径（开发环境由 Vite proxy 转发到 :8080）
VITE_API_BASE_URL=/api/v1


# ============================================
# 后端配置（点号分隔嵌套键）
# ============================================

# --- 服务配置 ---
# server.port=8080
# server.mode=debug
# server.read_timeout=10s
# server.write_timeout=10s

# --- 数据库配置 ---
# database.driver=postgres
# database.host=127.0.0.1
# database.port=5432
# database.user=postgres
# database.password=your_password_here
# database.dbname=isolo_news
# database.sslmode=disable
# database.max_open_conns=25
# database.max_idle_conns=10
# database.conn_max_lifetime=5m

# --- JWT 认证 ---
# auth.jwt_secret=your_jwt_secret_here
# auth.access_token_ttl=7200
# auth.refresh_token_ttl=2592000
# auth.email_verify_code_ttl=600

# --- SMTP 邮件 ---
# smtp.host=smtp.qq.com
# smtp.port=587
# smtp.username=your_email@qq.com
# smtp.password=your_smtp_password
# smtp.from=your_email@qq.com

# --- Casbin 权限 ---
# casbin.model_path=configs/casbin/model.conf
# casbin.policy_path=configs/casbin/policy.csv

# --- 采集器 ---
# collector.timeout=15
# collector.user_agent=Mozilla/5.0 (compatible; IsoloNewsBot/1.0)
# collector.max_retries=3
# collector.retry_delay=5

# --- Redis（预留） ---
# redis.host=127.0.0.1
# redis.port=6379
# redis.password=
# redis.db=0
