{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "coder",
  "disabled_providers": [],
  "provider": {
    "deepseek-v4": {
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.deepseek.com"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "limit": {
            "output": 32000,
            "context": 1000000
          }
        },
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro",
          "limit": {
            "output": 32000,
            "context": 1000000
          }
        }
      }
    }
  }
}